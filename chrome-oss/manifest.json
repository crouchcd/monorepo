{
  "name": "Old School Search",
  "version": "0.0.7",
  "description": "Replaces Google's latest search results list with the old, simple look",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["https://*.google.com/search*"],
      "css": ["contentStyle.css"],
      "js": ["contentScript.js"]
    }
  ],
  "icons": {
    "16": "favicon_io/favicon-16x16.png",
    "32": "favicon_io/favicon-32x32.png",
    "48": "favicon_io/favicon-48x48.png",
    "128": "favicon_io/favicon-128x128.png"
  }
}
